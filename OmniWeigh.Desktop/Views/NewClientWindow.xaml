<Window x:Class="OmniWeigh.Desktop.Views.NewClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouveau client" Height="420" Width="620" WindowStartupLocation="CenterOwner" Background="{StaticResource ApplicationBackgroundBrush}">
    <Grid Margin="12">
        <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="6" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Ajouter un nouveau client" Foreground="White" FontSize="16" FontWeight="Bold" />

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>

                    <!-- Required fields -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom / Raison sociale *" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Téléphone *" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Adresse e-mail *" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <!-- Optional fields -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Adresse ligne 1" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Address1, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Adresse ligne 2" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Address2, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ville" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Code Postal" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}" Height="28" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <!-- Country on top-right spanning two rows -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Visibility="Collapsed" />
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <TextBlock Text="Pays" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Width="200" Height="28" ItemsSource="{Binding Countries}" SelectedItem="{Binding Country}" Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" Foreground="White" />

                    <Button Content="Annuler" Width="96" Height="32" Margin="12,0,8,0" Command="{Binding CancelCommand}" />
                    <Button Content="Enregistrer" Width="120" Height="32" Background="{StaticResource SaveButtonBrush}" Foreground="White" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
