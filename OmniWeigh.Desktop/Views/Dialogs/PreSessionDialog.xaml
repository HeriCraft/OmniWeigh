<Window x:Class="OmniWeigh.Desktop.Views.Dialogs.PreSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouvelle Session" Height="250" Width="450" WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Nouvelle Session de Pesée" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            
            <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="14" Foreground="#A0AEC0" LineHeight="20">
                Vous êtes sur le point de démarrer une session continue. 
                <LineBreak/>
                <Run FontWeight="SemiBold" Foreground="#FC8181">Toutes les pesées enregistrées feront partie du même document.</Run>
                <LineBreak/>
                Une session ne peut pas être mise en pause une fois commencée.
            </TextBlock>
            
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Annuler" Width="100" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{DynamicResource SecondaryDialogButton}" />
                <Button Content="Commencer la session" Width="160" Click="BtnStart_Click" Style="{DynamicResource PrimaryDialogButton}" />
            </StackPanel>
        </Grid>
</Window>
