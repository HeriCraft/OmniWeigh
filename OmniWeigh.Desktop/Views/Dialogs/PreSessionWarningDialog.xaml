<Window x:Class="OmniWeigh.Desktop.Views.Dialogs.PreSessionWarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avertissement de Session" Height="280" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource ApplicationBackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{StaticResource AccentWarningBrush}" BorderThickness="2" CornerRadius="8" Background="{StaticResource CardBackgroundBrush}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="⚠️" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="NOUVELLE SESSION DE PESÉE" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Une session de pesée est constituée d'une série d'enregistrements successifs rattachés à un même document." 
                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,10"/>
                <TextBlock Text="Attention : Une fois commencée, une session ne peut être ni mise en pause, ni suspendue, ni interrompue pour quelque raison que ce soit. Elle doit être menée à son terme sans interruption." 
                           Foreground="{StaticResource AccentWarningBrush}" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Annuler" Click="BtnCancel_Click" Background="{StaticResource ResetButtonBrush}" Foreground="White" Height="35" BorderThickness="0" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                <Button Grid.Column="2" Content="Commencer la session" Click="BtnStart_Click" Background="{StaticResource AccentInfoBrush}" Foreground="White" FontWeight="Bold" Height="35" BorderThickness="0" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
