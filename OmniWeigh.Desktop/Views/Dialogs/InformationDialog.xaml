<Window x:Class="OmniWeigh.Desktop.Views.Dialogs.InformationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information" Height="200" Width="400" WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentInfoBrush}" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText" Text="INFORMATION" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Message" 
                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,10" VerticalAlignment="Center"/>

            <Button Grid.Row="2" Content="OK" Click="BtnOk_Click" Width="100" HorizontalAlignment="Right" Style="{DynamicResource PrimaryDialogButton}"/>
        </Grid>
    </Border>
</Window>
