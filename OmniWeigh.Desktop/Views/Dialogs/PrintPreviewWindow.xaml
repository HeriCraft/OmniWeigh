<Window x:Class="OmniWeigh.Desktop.Views.Dialogs.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aperçu avant impression" Height="800" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#F0F4F8" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Imprimer / PDF" Width="120" Height="30" Margin="0,0,10,0" Background="#1C3A6C" Foreground="White" BorderThickness="0" Click="BtnPrint_Click"/>
                <Button Content="Fermer" Width="100" Height="30" Background="#E2E8F0" Foreground="Black" BorderThickness="0" Click="BtnClose_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="DarkGray">
            <FlowDocumentScrollViewer Name="DocViewer" Margin="20" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
        </Border>
    </Grid>
</Window>
