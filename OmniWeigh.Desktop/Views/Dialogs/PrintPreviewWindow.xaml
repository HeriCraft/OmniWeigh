<Window x:Class="OmniWeigh.Desktop.Views.Dialogs.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aperçu avant impression" Height="800" Width="900" WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="Transparent" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Imprimer / PDF" Width="140" Margin="0,0,10,0" Click="BtnPrint_Click" Style="{DynamicResource PrimaryDialogButton}"/>
                <Button Content="Fermer" Width="100" Click="BtnClose_Click" Style="{DynamicResource SecondaryDialogButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="DarkGray">
            <FlowDocumentScrollViewer Name="DocViewer" Margin="20" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
        </Border>
    </Grid>
</Window>
