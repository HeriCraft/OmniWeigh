<UserControl x:Class="OmniWeigh.Desktop.Views.Pages.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Clients" Foreground="White" FontSize="20" FontWeight="Bold" Margin="4" />

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox Width="420" Height="32" VerticalAlignment="Center"
                             Text="{Binding ClientSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource FieldBackgroundBrush}"
                             BorderBrush="{StaticResource FieldBorderBrush}"
                             Foreground="White" Padding="8,4" />
                    <Button Content="✖" Command="{Binding ClearClientSearchCommand}" Width="36" Height="32" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ClientsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          RowBackground="{StaticResource FieldBackgroundBrush}"
                          AlternatingRowBackground="{StaticResource CardBackgroundBrush}"
                          GridLinesVisibility="None"
                          Foreground="White"
                          Margin="0,12,0,0"
                          Background="Transparent"
                          ColumnHeaderHeight="38">

                    <!-- Amélioration visibilité : header sombre + texte blanc semi-gras -->
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Référence client" Binding="{Binding Reference}" Width="200" />
                        <DataGridTextColumn Header="Nom / Raison sociale" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Phone}" Width="180" />
                        <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
