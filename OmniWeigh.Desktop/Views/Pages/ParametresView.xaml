<UserControl x:Class="OmniWeigh.Desktop.Views.Pages.ParametresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Modern Sidebar TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TabStripPlacement" Value="Left"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentInfoBrush}"/>
                                <Setter Property="Background" Value="{StaticResource FieldBackgroundFocusedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#A0B2C6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="20,15" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentInfoBrush}" FontSize="22" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Paramètres du Système" Foreground="White" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding SaveCommand}" Background="{StaticResource SaveButtonBrush}" Foreground="White" Height="36" Padding="20,0" BorderThickness="0" Cursor="Hand">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sauvegarder les paramètres" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="0,20,20,20">
            <TabControl>
                <!-- Tab 1: Paramètres de l'entreprise -->
                <TabItem Header="Entreprise &amp; Identité">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="30,0,0,0">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                            
                            <!-- Logo Section -->
                            <TextBlock Text="Identité Visuelle" Style="{StaticResource SectionHeader}"/>
                            <Border Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Logo Preview Box -->
                                    <Border Width="120" Height="120" Background="{StaticResource ApplicationBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,24,0">
                                        <Grid>
                                            <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource FieldBorderBrush}" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CompanyLogoPath}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CompanyLogoPath}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Image Source="{Binding CompanyLogoPath}" Stretch="Uniform" Margin="8"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Upload Controls -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Logo d'entreprise pour les rapports et bons de pesée." Foreground="White" FontSize="15" FontWeight="Medium" Margin="0,0,0,8"/>
                                        <TextBlock Text="Formats recommandés : PNG transparent ou JPG haute résolution." Foreground="{StaticResource MutedTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                        <Button Command="{Binding PickLogoCommand}" Width="160" Height="36" HorizontalAlignment="Left" Background="{StaticResource FieldBackgroundFocusedBrush}" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Importer un logo" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button.Content>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="Informations Générales" Style="{StaticResource SectionHeader}"/>
                            
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nom de l'entreprise" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Adresse (Ligne 1)" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanyAddress1, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                                    
                                    <TextBlock Text="Téléphone" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Slogan (Optionnel)" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanySlogan, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Adresse (Ligne 2)" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanyAddress2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                                    
                                    <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Paramètres de l'application (Hardware) -->
                <TabItem Header="Matériel &amp; Balance">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="30,0,0,0">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                            <TextBlock Text="Configuration du Pont-Bascule" Style="{StaticResource SectionHeader}"/>

                            <Border Background="{StaticResource FieldBackgroundBrush}" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="24" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Pilote (Driver) Principal" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding AvailableScaleDrivers}" SelectedItem="{Binding SelectedScaleDriver}" Margin="0,0,0,24"/>

                                    <TextBlock Text="Paramètres de Communication Série (RS232/USB)" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Port COM" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox ItemsSource="{Binding AvailableComPorts}" SelectedItem="{Binding SelectedComPort}" Margin="0,0,0,16"/>

                                            <TextBlock Text="Bits de données (Data Bits)" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox ItemsSource="{Binding AvailableDataBits}" SelectedItem="{Binding SelectedDataBits}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Vitesse (Baud Rate)" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox ItemsSource="{Binding AvailableBaudRates}" SelectedItem="{Binding SelectedBaudRate}" Margin="0,0,0,16"/>

                                            <TextBlock Text="Parité (Parity)" Style="{StaticResource LabelStyle}"/>
                                            <ComboBox ItemsSource="{Binding AvailableParities}" SelectedItem="{Binding SelectedParity}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#1A2ECC71" BorderBrush="{StaticResource AccentSuccessBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentSuccessBrush}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Les modifications des paramètres matériels nécessitent un redémarrage de l'application pour prendre effet pleinement sur le module de pesée." Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Informations du créateur -->
                <TabItem Header="À propos du Créateur">
                    <Grid Margin="30,0,0,0">
                        <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                            <TextBlock Text="Licence et Informations" Style="{StaticResource SectionHeader}"/>
                            
                            <Border Background="{StaticResource ApplicationBackgroundBrush}" CornerRadius="12" Padding="40" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Branding Logo -->
                                    <Border Width="120" Height="120" Background="{StaticResource FieldBackgroundBrush}" CornerRadius="60" Margin="0,0,40,0" VerticalAlignment="Top">
                                        <svg:SvgViewbox Source="pack://application:,,,/Assets/logo_dark.svg" Width="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="OmniWeigh Enterprise" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                            <Border Background="{StaticResource AccentInfoBrush}" CornerRadius="4" Padding="8,3" Margin="0,0,12,0">
                                                <TextBlock Text="PRO EDITION" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Version " Foreground="{StaticResource MutedTextBrush}" FontSize="15" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource MutedTextBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="Conçu et développé par l'ingénierie :" Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,0,0,6"/>
                                        <TextBlock Text="Granix" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,24"/>
                                        
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentInfoBrush}" FontSize="18" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="+261 33 51 172 07  (Support WhatsApp)" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,32">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentInfoBrush}" FontSize="18" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="heriniaina.randrianasolo@hotmail.com" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                                        </Grid>

                                        <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource SeparatorBrush}" Padding="0,20,0,0">
                                            <TextBlock Text="© 2026 Granix. Tous droits réservés. Produit distribué sous licence commerciale restreinte." Foreground="{StaticResource MutedTextBrush}" FontSize="13" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
