<Window x:Class="OmniWeigh.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:OmniWeigh.Desktop.Converters;assembly=OmniWeigh.Desktop"
        mc:Ignorable="d"
        Title="OmniWeigh" Height="840" Width="1150"
        Background="{StaticResource ApplicationBackgroundBrush}" FontFamily="Segoe UI">

    <!-- Resources have been centralized into Themes/Colors.xaml and Themes/Styles.xaml -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="⚖️ OmniWeigh" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Pesage • Métrologie • Maintenance" Foreground="{StaticResource MutedSecondaryBrush}" FontSize="11" Margin="2,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10,10,10,0">
                <!-- Menu buttons: use SelectMenuCommand to update SelectedMenu in the ViewModel -->
                <Button Content="🏠   Accueil" Tag="Accueil" Command="{Binding SelectMenuCommand}" CommandParameter="Accueil" Click="BtnAccueil_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Accueil">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="🚛   Prise de poids" Tag="PriseDePoids" Command="{Binding SelectMenuCommand}" CommandParameter="PriseDePoids" Click="BtnPrisePoids_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="PriseDePoids">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="🕒   Historique" Tag="Historique" Command="{Binding SelectMenuCommand}" CommandParameter="Historique" Click="BtnHistorique_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Historique">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="📊   Rapports" Tag="Rapports" Command="{Binding SelectMenuCommand}" CommandParameter="Rapports" Click="BtnRapports_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Rapports">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="👥   Clients" Tag="Clients" Command="{Binding SelectMenuCommand}" CommandParameter="Clients" Click="BtnClients_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Clients">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="📦   Produits" Tag="Produits" Command="{Binding SelectMenuCommand}" CommandParameter="Produits" Click="BtnProduits_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Produits">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="⚙️   Paramètres" Tag="Parametres" Command="{Binding SelectMenuCommand}" CommandParameter="Parametres" Click="BtnParametres_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMenu}" Value="Parametres">
                                    <Setter Property="Background" Value="{StaticResource ActiveMenuBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" Margin="15" Padding="15" Background="{StaticResource PanelDarkerBrush}" CornerRadius="6">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentSuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Connexion" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StringFormat='Balance : {0}', Path=BalanceModel}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2"/>
                    <TextBlock Text="{Binding StringFormat='Port : {0}', Path=ComPort}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2"/>
                    <TextBlock Text="{Binding StringFormat='Mode : {0}', Path=OperationMode}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,8"/>

                    <Separator Background="{StaticResource SeparatorBrush}" Margin="0,5"/>
                    <TextBlock Text="{Binding OperatorName, StringFormat='Opérateur : {0}'}" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <ContentControl x:Name="ContentRegion" Grid.Column="1" Margin="20" />
    </Grid>
</Window>