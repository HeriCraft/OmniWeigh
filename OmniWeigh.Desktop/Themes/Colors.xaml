<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Palette: industrial dark theme -->
  <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#08101E" />
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0A1424" />
  <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0F1E36" />
  <SolidColorBrush x:Key="PanelDarkerBrush" Color="#0D1B30" />
  <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#162A4A" />
  <SolidColorBrush x:Key="FieldBackgroundFocusedBrush" Color="#1A355E" />
  <SolidColorBrush x:Key="FieldBorderBrush" Color="#243F6C" />
  <SolidColorBrush x:Key="ActiveMenuBackgroundBrush" Color="#12284C" />
  <SolidColorBrush x:Key="MenuForegroundBrush" Color="#A0B2C6" />
  <SolidColorBrush x:Key="MutedSecondaryBrush" Color="#5A6E85" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="#6C829D" />
  <SolidColorBrush x:Key="SeparatorBrush" Color="#1B2E4A" />

  <!-- Accents -->
  <SolidColorBrush x:Key="AccentInfoBrush" Color="#3498DB" />
  <SolidColorBrush x:Key="AccentSuccessBrush" Color="#2ECC71" />
  <SolidColorBrush x:Key="AccentWarningBrush" Color="#F1C40F" />

  <!-- Action colors -->
  <SolidColorBrush x:Key="SaveButtonBrush" Color="#1A5276" />
  <SolidColorBrush x:Key="PrintButtonBrush" Color="#1E8449" />
  <SolidColorBrush x:Key="ResetButtonBrush" Color="#283747" />

  <SolidColorBrush x:Key="VersionTextBrush" Color="#4A5A70" />

</ResourceDictionary>
